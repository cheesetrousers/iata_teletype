Screen {
    background: $surface-darken-1;
}

#output-log {
    height: 1fr;
    border: solid green;
    padding: 1;
    color: #33ff33;
    background: black;
}

#input-form {
    height: 15;
    dock: bottom;
    border: solid blue;
    padding: 1;
}

#top-row {
    height: 3;
    margin-bottom: 1;
}

.in-small {
    width: 1fr;
}

#btn-send {
    width: 16;
}

#in-body {
    height: 1fr;
    border: solid green;
    background: $surface;
}
